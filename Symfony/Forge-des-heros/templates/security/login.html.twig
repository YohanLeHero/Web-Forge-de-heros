{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
  <div style="max-width: 420px; margin: 40px auto; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;">
    <h1>Login</h1>

    {% if error %}
      <div style="background: #fee; border: 1px solid #f99; padding: 10px; margin-bottom: 12px;">
        {{ error.messageKey|trans(error.messageData, 'security') }}
      </div>
    {% endif %}

    <form method="post">
      <label for="inputEmail">Email</label><br />
      <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" required autofocus style="width: 100%; padding: 8px; margin: 6px 0 12px;" />

      <label for="inputPassword">Password</label><br />
      <input type="password" name="password" id="inputPassword" autocomplete="current-password" required style="width: 100%; padding: 8px; margin: 6px 0 12px;" />

      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

      <button type="submit" style="padding: 8px 12px;">Sign in</button>
    </form>

    <p style="margin-top: 12px;">
      No account? <a href="{{ path('app_register') }}">Register</a>
    </p>
  </div>
{% endblock %}

