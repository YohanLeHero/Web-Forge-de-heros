{% extends 'base.html.twig' %}

{% block title %}New Party{% endblock %}

{% block body %}
  <div style="max-width: 720px; margin: 40px auto; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;">
    <h1>New Party</h1>

    {{ form_start(form) }}
      {{ form_row(form.name) }}
      {{ form_row(form.description) }}
      {{ form_row(form.maxSize, { label: 'Max size' }) }}
      <button type="submit" style="padding: 8px 12px;">Create</button>
      <a href="{{ path('app_parties_index') }}" style="margin-left: 10px;">Cancel</a>
    {{ form_end(form) }}
  </div>
{% endblock %}

