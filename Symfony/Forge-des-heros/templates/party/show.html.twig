{% extends 'base.html.twig' %}

{% block title %}{{ party.name }}{% endblock %}

{% block body %}
  <div style="max-width: 900px; margin: 40px auto; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;">
    <p><a href="{{ path('app_parties_index') }}">← Back</a></p>

    <h1>{{ party.name }}</h1>
    <p class="text-muted">{{ party.description }}</p>
    <p>Members: {{ memberCount }}/{{ party.maxSize }} (places left: {{ party.maxSize - memberCount }})</p>

    {% for label, messages in app.flashes %}
      {% for m in messages %}
        <div style="background:#fee; border:1px solid #f99; padding:8px; margin:10px 0;">{{ m }}</div>
      {% endfor %}
    {% endfor %}

    <h3>Members</h3>
    {% if party.character is empty %}
      <p>No members.</p>
    {% else %}
      <ul>
        {% for c in party.character %}
          <li>
            <a href="{{ path('app_characters_show', {id: c.id}) }}">{{ c.name }}</a>
            ({{ c.characterClass ? c.characterClass.name : '' }})
          </li>
        {% endfor %}
      </ul>
    {% endif %}

    <h3>Join / Leave</h3>
    <p>Choose one of your characters:</p>

    <form method="post" action="{{ path('app_parties_join', {id: party.id}) }}" style="display:flex; gap: 8px; margin-bottom: 10px;">
      <select name="characterId" style="flex: 1; padding: 8px;">
        {% for c in myCharacters %}
          <option value="{{ c.id }}">{{ c.name }}</option>
        {% endfor %}
      </select>
      <button type="submit" style="padding: 8px 12px;">Join</button>
    </form>

    <form method="post" action="{{ path('app_parties_leave', {id: party.id}) }}" style="display:flex; gap: 8px;">
      <select name="characterId" style="flex: 1; padding: 8px;">
        {% for c in myCharacters %}
          <option value="{{ c.id }}">{{ c.name }}</option>
        {% endfor %}
      </select>
      <button type="submit" style="padding: 8px 12px;">Leave</button>
    </form>
  </div>
{% endblock %}

